# 本地手动运行 ci/upload-to-gdrive.ps1 时读取的非敏感配置。
# 复制为 ci/ci.env（已被 .gitignore 忽略）并填入实际值。
# 在 CI 中这些值由 GitHub Actions Variables 注入，无需此文件。

# My Drive 内用于存放产物的固定文件夹 ID（对外共享的就是这个文件夹）。
# 取自文件夹 URL：https://drive.google.com/drive/folders/<这里就是ID>
GDRIVE_FOLDER_ID=<文件夹ID>

# 触发链路相关（仅上游侧需要配置，此处仅作备忘）。
FORK_DISPATCH_REPO=AphrixZjr/subtle
